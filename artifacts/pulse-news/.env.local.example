# Copy this file to .env.local and fill in your key.
# Vite loads .env.local automatically in dev mode.
#
# With this set, Bref will fetch today's top AI news from RSS feeds
# and use Claude to select + enrich the 6 most important stories.
# Without it, the app falls back to the built-in static dataset.

ANTHROPIC_API_KEY=sk-ant-...
